{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "aiCode": { "type": "string", "description": "Code to unlock AI features" }
      },
      "required": ["uid", "email"]
    },
    "Category": {
      "title": "Category",
      "description": "Learning category (e.g., Grammar Foundations)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "title"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A lesson within a category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "categoryId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "tips": { "type": "array", "items": { "type": "string" } },
        "audioUrl": { "type": "string", "description": "URL for listening audio" },
        "readingText": { "type": "string", "description": "Text for reading section" },
        "createdBy": { "type": "string", "description": "UID of the user who created this" },
        "isCustom": { "type": "boolean" }
      },
      "required": ["id", "categoryId", "title"]
    },
    "Question": {
      "title": "Question",
      "description": "A quiz question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lessonId": { "type": "string" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "explanation": { "type": "string" }
      },
      "required": ["id", "lessonId", "text", "options", "correctAnswer"]
    },
    "AdminConfig": {
      "title": "AdminConfig",
      "description": "Global admin configuration",
      "type": "object",
      "properties": {
        "aiUnlockCode": { "type": "string", "description": "The secret code to unlock AI features" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Learning categories"
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Quiz questions"
    },
    "/admin/config": {
      "schema": "AdminConfig",
      "description": "Global admin configuration"
    }
  }
}
