// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - photoURL: string
//   - role: string (admin/user)
//   - aiCode: string
//
// Collection: categories
// Fields:
//   - id: string (required)
//   - title: string (required)
//   - icon: string
//   - description: string
//
// Collection: lessons
// Fields:
//   - id: string (required)
//   - categoryId: string (required)
//   - title: string (required)
//   - description: string
//   - content: string
//   - tips: list of strings
//   - audioUrl: string
//   - readingText: string
//   - createdBy: string
//   - isCustom: bool
//
// Collection: questions
// Fields:
//   - id: string (required)
//   - lessonId: string (required)
//   - text: string (required)
//   - options: list of strings (required)
//   - correctAnswer: number (required)
//   - explanation: string
//
// Collection: admin
// Document: config
// Fields:
//   - aiUnlockCode: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "lukmanzakaria005@gmail.com";
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100 &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100));
    }

    function isValidCategory(data) {
      return hasRequiredFields(['id', 'title']) &&
             data.id is string &&
             data.title is string &&
             data.title.size() < 100;
    }

    function isValidLesson(data) {
      return hasRequiredFields(['id', 'categoryId', 'title']) &&
             data.id is string &&
             data.categoryId is string &&
             data.title is string &&
             data.title.size() < 200 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('content' in data) || (data.content is string && data.content.size() < 50000));
    }

    function isValidQuestion(data) {
      return hasRequiredFields(['id', 'lessonId', 'text', 'options', 'correctAnswer']) &&
             data.id is string &&
             data.lessonId is string &&
             data.text is string &&
             data.text.size() < 2000 &&
             data.options is list &&
             data.options.size() <= 10 &&
             data.correctAnswer is int;
    }

    function isValidAdminConfig(data) {
      return (!('aiUnlockCode' in data) || (data.aiUnlockCode is string && data.aiUnlockCode.size() < 50));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uId} {
      allow read: if isAuthenticated() && (request.auth.uid == uId || isAdmin());
      allow create: if isOwner(uId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == "lukmanzakaria005@gmail.com"));
      allow update: if isOwner(uId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(request.resource.data);
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidLesson(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidQuestion(request.resource.data);
      allow update, delete: if isAdmin() || isAuthenticated(); 
    }

    match /admin/config {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidAdminConfig(request.resource.data);
    }

    match /vocabulary/{word} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /speaking_prompts/{promptId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /writing_tasks/{taskId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
